datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  ADMIN
  MENTOR
}

enum BatchStatus {
  ACTIVE
  CLOSED
}

enum BatchType {
  LIVE
  COURSE
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

model User {
  id            Int        @id @default(autoincrement())
  name          String
  email         String     @unique
  phone_number  String
  password_hash String
  role          Role       @default(USER)
  status        UserStatus @default(ACTIVE)
  deleted_at    DateTime?
  banned_at     DateTime?
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt

  enrollments       Enrollment[]
  auditLogs         AuditLog[]
  mentorProfile     MentorProfile?
  material_progress MaterialProgress[]

  @@index([role])
  @@index([status])
  @@index([email])
}

model MentorProfile {
  id Int @id @default(autoincrement())

  user_id Int  @unique
  user    User @relation(fields: [user_id], references: [id])

  name   String
  bio    String?
  avatar String?

  linkedin String?
  github   String?
  website  String?

  experience_years Int?

  total_reviews Int @default(0)

  is_active Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  batches      Batch[]
  batchMentors BatchMentor[]

  @@index([is_active])
}

model BatchMentor {
  id        Int @id @default(autoincrement())
  batch_id  Int
  mentor_id Int

  created_at DateTime  @default(now())
  deleted_at DateTime?

  batch  Batch         @relation(fields: [batch_id], references: [id])
  mentor MentorProfile @relation(fields: [mentor_id], references: [id])

  @@unique([batch_id, mentor_id])
}

model Tag {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  created_at DateTime @default(now())

  batches BatchTag[]
}

model Batch {
  id Int @id @default(autoincrement())

  mentor_id Int?
  mentor    MentorProfile? @relation(fields: [mentor_id], references: [id])

  title       String      @unique
  description String?
  image_url   String?
  type        BatchType   @default(LIVE)
  start_date  DateTime?
  end_date    DateTime?
  price       Int
  quota       Int?
  status      BatchStatus @default(ACTIVE)
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt

  enrollments Enrollment[]
  materials   Material[]
  tags        BatchTag[]
  mentors     BatchMentor[]
}

model BatchTag {
  batch_id Int
  tag_id   Int

  batch Batch @relation(fields: [batch_id], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([batch_id, tag_id])
}

model Enrollment {
  id             Int       @id @default(autoincrement())
  user_id        Int
  batch_id       Int
  enrolled_at    DateTime  @default(now())
  payment_status String    @default("PENDING")
  expires_at     DateTime?
  payment_ref    String?
  invoice_number String?   @unique
  price          Int?
  discount       Int?      @default(0)
  total_paid     Int?

  user  User  @relation(fields: [user_id], references: [id])
  batch Batch @relation(fields: [batch_id], references: [id])

  @@unique([user_id, batch_id])
}

model Material {
  id         Int      @id @default(autoincrement())
  title      String
  content    String   @db.Text
  batch_id   Int
  order      Int
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  video_url  String?

  batch Batch @relation(fields: [batch_id], references: [id])

  progress MaterialProgress[]
}

model MaterialProgress {
  id          Int @id @default(autoincrement())
  user_id     Int
  material_id Int

  completed Boolean @default(false)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user     User     @relation(fields: [user_id], references: [id])
  material Material @relation(fields: [material_id], references: [id])

  @@unique([user_id, material_id])
}

model AuditLog {
  id Int @id @default(autoincrement())

  admin_id  Int
  action    String
  target_id Int?
  target    String?

  metadata Json?

  created_at DateTime @default(now())

  admin User @relation(fields: [admin_id], references: [id])
}
